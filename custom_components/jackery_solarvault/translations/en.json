        "data": {
          "create_calculated_power_sensors": "Create calculated net-power sensors",
          "create_smart_meter_derived_sensors": "Create calculated smart-meter sensors",
          "password": "Password",
          "username": "Email"
        },
        "data_description": {
          "create_calculated_power_sensors": "Creates optional local net-power sensors from values already delivered by Jackery: main battery charge minus discharge, battery-system/stack charge minus discharge, and grid-side input minus output. These sensors are useful for dashboards that need a signed net value, but they are not separate app values. Disabled by default so raw Jackery values stay unambiguous.",
          "create_smart_meter_derived_sensors": "Creates additional netted sensors, gross phase-flow sensors, and calculated home consumption from Jackery reported live home load when available, otherwise Smart Meter phase values plus Jackery grid-side input/output. Disable if you only want raw Jackery values."
        },
        "description": "Enter your Jackery cloud credentials. Device, region and MQTT credentials are discovered automatically from Jackery's cloud/app protocol; manual IDs are intentionally not exposed.\n\nThe optional calculated net-power sensors are local derivations from Jackery raw values. Enable them only if you need an additional signed net value for dashboards.\n\nJackery usually allows only one active session per account. If you also want to use the mobile app concurrently, create a secondary account in the Jackery app and share the system there via QR code. The QR code is generated by the Jackery app and is not exposed by the cloud API to Home Assistant.",
        "title": "Jackery SolarVault"
      }
    }
