{
  "domain": "jackery_solarvault",
  "name": "Jackery SolarVault",
  "after_dependencies": [
    "bluetooth",
    "dhcp",
    "http",
    "mqtt",
    "recorder",
    "zeroconf"
  ],
  "bluetooth": [
    {
      "connectable": true,
      "manufacturer_id": 18434,
      "service_uuid": "0000bdee-0000-1000-8000-00805f9b34fb"
    }
  ],
  "codeowners": [
    "@Bigdaddy1990"
  ],
  "config_flow": true,
  "dependencies": [],
  "dhcp": [
    {
      "hostname": "lwip-*",
      "macaddress": "80F1B2*"
    }
  ],
  "documentation": "https://github.com/Bigdaddy1990/jackery_solarvault",
  "integration_type": "hub",
  "iot_class": "cloud_polling",
  "issue_tracker": "https://github.com/Bigdaddy1990/jackery_solarvault/issues",
  "loggers": [
    "aiohttp",
    "aiomqtt",
    "custom_components.jackery_solarvault"
  ],
  "mqtt": [
    "hb/#"
  ],
  "quality_scale": "custom",
  "requirements": [
    "aiomqtt>=2.5.0",
    "bleak-retry-connector>=3.5.0",
    "segno>=1.6.0"
  ],
  "version": "0.1.1",
  "zeroconf": [
    {
      "type": "_api._tcp.local.",
      "properties": {
        "device": "SolarVault"
      }
    },
    {
      "type": "_http._tcp.local.",
      "properties": {
        "device": "SolarVault"
      }
    }
  ]
}
