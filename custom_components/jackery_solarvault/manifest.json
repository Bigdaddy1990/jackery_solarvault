{
  "domain": "jackery_solarvault",
  "name": "Jackery SolarVault",
  "after_dependencies": [
    "bluetooth",
    "dhcp",
    "http",
    "mdns",
    "mqtt",
    "recorder",
    "zeroconf"
  ],
  "bluetooth": [
    {
      "connectable": true,
      "manufacturer_id": 18434,
      "service_uuid": "0000bdee-0000-1000-8000-00805f9b34fb"
    }
  ],
  "codeowners": [
    "@Bigdaddy1990"
  ],
  "config_flow": true,
  "dependencies": [],
  "dhcp": [
    {
      "hostname": "lwip-*",
      "macaddress": "80F1B2F9E348"
    }
  ],
  "documentation": "https://github.com/Bigdaddy1990/jackery_solarvault",
  "integration_type": "hub",
  "iot_class": "cloud_polling",
  "issue_tracker": "https://github.com/Bigdaddy1990/jackery_solarvault/issues",
  "loggers": [
    "custom_components.jackery_solarvault",
    "custom_components.jackery_solarvault.client",
    "custom_components.jackery_solarvault.client.api",
    "custom_components.jackery_solarvault.client.ble",
    "custom_components.jackery_solarvault.client.ble_transport",
    "custom_components.jackery_solarvault.client.mqtt_push",
    "custom_components.jackery_solarvault.client.local_mqtt",
    "custom_components.jackery_solarvault.client.third_party_mqtt_codec",
    "aiomqtt",
    "aiodns",
    "aiohttp",
    "bluetooth",
    "http",
    "zeroconf"
  ],
  "mqtt": [
    "jackery/#",
    "hb/#"
  ],
  "quality_scale": "custom",
  "requirements": [
    "aiomqtt>=2.5.0"
  ],
  "version": "0.1.1",
  "zeroconf": [
    {
      "type": "_api._tcp.local.",
      "properties": {
        "device": "SolarVault"
      }
    },
    {
      "type": "_api._udp.local.",
      "properties": {
        "device": "SolarVault"
      }
    },
    {
      "type": "_http._tcp.local.",
      "properties": {
        "device": "SolarVault"
      }
    }
  ]
